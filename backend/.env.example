# nginx-shop 配置契约
# 复制为 backend/.env.develop（开发）或 backend/.env.product（生产）后按实际环境填写
# .env.develop 已被 .gitignore 忽略，请勿提交真实凭据


# --- Redis（聊天限流）---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# --- Bearer Token 认证 ---
AUTH_TOKEN_SECRET=change-me-in-production
AUTH_TOKEN_MAX_AGE=86400

# --- MySQL ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=nginx_shop

# --- PostgreSQL（LangGraph checkpointer）---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=langgraph
POSTGRES_PASSWORD=langgraph
POSTGRES_DB=langgraph

# --- Agent 长对话摘要 ---
AGENT_SUMMARY_TRIGGER_FRACTION=0.8
AGENT_SUMMARY_KEEP_MESSAGES=20
AGENT_RECURSION_LIMIT=25

# --- Flask ---
DEBUG=True
FLASK_ENV=development
SECRET_KEY=change-me

# --- 中间件 ---
LOG_DIR=

PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1

# --- DeepSeek API Key ---
DEEPSEEK_API_KEY=

# --- Tavily 联网搜索 ---
TAVILY_API_KEY=
TAVILY_SEARCH_MAX_RESULTS=3
BAIDU_SEARCH_MAX_RESULTS=3
