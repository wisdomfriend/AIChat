# Redis（聊天限流，非 Session 存储）
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=test

# Bearer Token 认证（必填，生产环境请修改）
AUTH_TOKEN_SECRET=change-me-in-production
AUTH_TOKEN_MAX_AGE=86400

# 数据库配置MYSQL_ROOT_PASSWORD=your_secure_root_password
MYSQL_HOST=mysql
MYSQL_PORT=23306
MYSQL_USER=test
MYSQL_PASSWORD=test
MYSQL_DB=flask_app

# Flask 配置
DEBUG=True
FLASK_ENV=development
SECRET_KEY=test

# 中间件配置
CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
LOG_DIR=

# 前端开发（可选，生产同源部署可省略）
# VITE_API_BASE_URL=http://127.0.0.1:5000

# 禁用python输出缓冲
PYTHONUNBUFFERED=1
# 阻止Python生成字节码缓存文件（.pyc 文件）
PYTHONDONTWRITEBYTECODE=1

# DeepSeek API Key
DEEPSEEK_API_KEY=

# Tavily 联网搜索
TAVILY_API_KEY=
TAVILY_SEARCH_MAX_RESULTS=3
BAIDU_SEARCH_MAX_RESULTS=3
